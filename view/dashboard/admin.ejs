<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard Admin - Ticket Concert</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css"
    />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: Arial, Helvetica, sans-serif;
        background: #f0f2f5;
        color: #1a1a2e;
        font-size: 14px;
      }

      #navbar {
        position: sticky;
        top: 0;
        z-index: 50;
        background: #1a1a2e;
        padding: 0 20px;
        display: flex;
        align-items: center;
        height: 54px;
        transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      }
      #navbar.scrolled {
        margin: 8px 14px 0;
        border-radius: 16px;
        height: 48px;
      }
      .nav-brand {
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: 15px;
        font-weight: 600;
        color: #fff;
      }
      .nav-brand i {
        font-size: 20px;
        color: #a78bfa;
      }
      .nav-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #4ade80;
        animation: pulse 2s infinite;
      }
      @keyframes pulse {
        0%,
        100% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.5;
          transform: scale(0.8);
        }
      }

      .wrap {
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
      }
      .stat-card {
        border-radius: 14px;
        padding: 16px;
        transition: transform 0.15s;
        cursor: default;
      }
      .stat-card:hover {
        transform: translateY(-3px);
      }
      .stat-card .lbl {
        font-size: 12px;
        font-weight: 500;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 7px;
        opacity: 0.85;
      }
      .stat-card .lbl i {
        font-size: 15px;
      }
      .stat-card .val {
        font-size: 24px;
        font-weight: 700;
      }
      .sc-purple {
        background: #ede9fe;
        color: #4c1d95;
      }
      .sc-purple .val {
        color: #5b21b6;
      }
      .sc-blue {
        background: #dbeafe;
        color: #1e3a5f;
      }
      .sc-blue .val {
        color: #1d4ed8;
      }
      .sc-teal {
        background: #ccfbf1;
        color: #134e4a;
      }
      .sc-teal .val {
        color: #0f766e;
      }
      .sc-green {
        background: #dcfce7;
        color: #14532d;
      }
      .sc-green .val {
        color: #15803d;
      }

      .panel {
        background: #fff;
        border: 0.5px solid #e2e8f0;
        border-radius: 14px;
        padding: 18px;
      }
      .panel-title {
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: #1a1a2e;
      }
      .panel-title i {
        font-size: 16px;
        color: #7c3aed;
      }

      .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-bottom: 8px;
      }
      .form-grid.three {
        grid-template-columns: 1fr 1fr 1fr;
      }
      .full {
        grid-column: 1 / -1;
      }
      .field-label {
        font-size: 11px;
        font-weight: 600;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 4px;
      }
      input,
      select,
      textarea {
        width: 100%;
        padding: 9px 11px;
        border: 1.5px solid #e2e8f0;
        border-radius: 9px;
        background: #f8fafc;
        color: #1a1a2e;
        font-size: 13px;
        outline: none;
        transition:
          border-color 0.15s,
          box-shadow 0.15s;
        font-family: inherit;
      }
      input:focus,
      select:focus,
      textarea:focus {
        border-color: #7c3aed;
        box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
        background: #fff;
      }
      input::placeholder,
      textarea::placeholder {
        color: #94a3b8;
      }
      textarea {
        resize: vertical;
        min-height: 70px;
        line-height: 1.5;
      }

      .btn {
        border: none;
        padding: 9px 16px;
        cursor: pointer;
        border-radius: 9px;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.15s;
        font-family: inherit;
      }
      .btn:active {
        transform: scale(0.97);
      }
      .btn-primary {
        background: #7c3aed;
        color: #fff;
      }
      .btn-primary:hover {
        background: #6d28d9;
      }
      .btn-warn {
        background: #f59e0b;
        color: #fff;
      }
      .btn-warn:hover {
        background: #d97706;
      }
      .btn-danger {
        background: #ef4444;
        color: #fff;
      }
      .btn-danger:hover {
        background: #dc2626;
      }
      .btn-ghost {
        background: #f1f5f9;
        color: #334155;
        border: 1px solid #e2e8f0;
      }
      .btn-ghost:hover {
        background: #e2e8f0;
      }
      .btn-sm {
        padding: 5px 10px;
        font-size: 12px;
      }

      .search-wrap {
        position: relative;
        margin-bottom: 12px;
      }
      .search-wrap i {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 15px;
      }
      .search-wrap input {
        padding-left: 32px;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12.5px;
      }
      thead th {
        background: #f8f4ff;
        color: #5b21b6;
        font-weight: 600;
        padding: 10px;
        text-align: left;
        border-bottom: 2px solid #ede9fe;
      }
      tbody td {
        padding: 9px 10px;
        border-bottom: 1px solid #f1f5f9;
        color: #334155;
        vertical-align: middle;
      }
      tbody tr:last-child td {
        border-bottom: none;
      }
      tbody tr {
        transition: background 0.1s;
      }
      tbody tr:hover td {
        background: #faf5ff;
      }

      .badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
      }
      .badge-green {
        background: #dcfce7;
        color: #15803d;
      }
      .badge-gray {
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #e2e8f0;
      }
      .badge-yellow {
        background: #fef9c3;
        color: #854d0e;
      }
      .badge-red {
        background: #fee2e2;
        color: #991b1b;
      }
      .empty-row td {
        color: #94a3b8;
        text-align: center;
        padding: 28px;
      }

      .loc-cell {
        display: flex;
        align-items: center;
        gap: 5px;
      }
      .loc-cell i {
        color: #7c3aed;
        font-size: 13px;
        flex-shrink: 0;
      }
      .date-cell {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .date-main {
        font-weight: 600;
        font-size: 12px;
        color: #334155;
      }
      .date-time {
        font-size: 11px;
        color: #7c3aed;
        font-weight: 500;
      }
      .time-cell {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .time-date {
        font-weight: 600;
        font-size: 12px;
        color: #334155;
      }
      .time-hour {
        font-size: 11px;
        color: #94a3b8;
      }

      .toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 200;
        background: #1a1a2e;
        border-radius: 12px;
        padding: 12px 18px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        color: #fff;
        transform: translateY(80px);
        opacity: 0;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        pointer-events: none;
        min-width: 220px;
      }
      .toast.show {
        transform: translateY(0);
        opacity: 1;
      }
      .toast i {
        font-size: 17px;
        color: #4ade80;
      }

      .modal-bg {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15, 15, 30, 0.45);
        z-index: 100;
        align-items: center;
        justify-content: center;
      }
      .modal-bg.open {
        display: flex;
      }
      .modal {
        background: #fff;
        border-radius: 16px;
        padding: 22px;
        width: 480px;
        max-width: 95vw;
        animation: slideUp 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
        max-height: 90vh;
        overflow-y: auto;
      }
      @keyframes slideUp {
        from {
          transform: translateY(20px);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(6px);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }
      .modal h2 {
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: #1a1a2e;
      }
      .modal h2 i {
        color: #7c3aed;
      }
      .modal-actions {
        display: flex;
        gap: 8px;
        margin-top: 12px;
      }

      .event-datetime-banner {
        background: #f8f4ff;
        border: 1.5px solid #ede9fe;
        border-radius: 10px;
        padding: 12px 14px;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 14px;
      }
      .event-datetime-banner i {
        font-size: 22px;
        color: #7c3aed;
      }
      .edb-main {
        font-size: 14px;
        font-weight: 700;
        color: #1a1a2e;
      }
      .edb-sub {
        font-size: 12px;
        color: #7c3aed;
        font-weight: 500;
      }
      .detail-row {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 14px;
      }
      .detail-label {
        font-size: 11px;
        font-weight: 600;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .detail-value {
        font-size: 13px;
        color: #1a1a2e;
        line-height: 1.5;
      }
      .detail-icon-row {
        display: flex;
        align-items: flex-start;
        gap: 6px;
      }
      .detail-icon-row i {
        color: #7c3aed;
        margin-top: 2px;
        flex-shrink: 0;
      }
      .divider {
        border: none;
        border-top: 1px solid #f1f5f9;
        margin: 14px 0;
      }
    </style>
  </head>
  <body>
    <div id="navbar">
      <div class="nav-brand">
        <i class="ti ti-ticket"></i>
        Concert Admin
        <div class="nav-dot"></div>
      </div>
    </div>

    <div class="wrap">
      <div class="stat-grid">
        <div class="stat-card sc-purple">
          <div class="lbl">
            <i class="ti ti-calendar-event"></i> Total event
          </div>
          <div class="val" id="totalEvent">0</div>
        </div>
        <div class="stat-card sc-blue">
          <div class="lbl"><i class="ti ti-ticket"></i> Total tiket</div>
          <div class="val" id="totalTicket">0</div>
        </div>
        <div class="stat-card sc-teal">
          <div class="lbl"><i class="ti ti-users"></i> Tiket terjual</div>
          <div class="val" id="ticketSold">0</div>
        </div>
        <div class="stat-card sc-green">
          <div class="lbl"><i class="ti ti-cash"></i> Revenue</div>
          <div class="val" id="revenue">Rp0</div>
        </div>
      </div>

      <div class="panel">
        <div class="panel-title"><i class="ti ti-plus"></i> Tambah event</div>
        <div class="form-grid">
          <input
            type="text"
            id="eventName"
            placeholder="Nama event"
            class="full"
          />
        </div>
        <div class="form-grid">
          <input
            type="text"
            id="eventLocation"
            placeholder="Lokasi venue (contoh: GBK, Jakarta)"
          />
          <select id="statusEvent">
            <option>Aktif</option>
            <option>Selesai</option>
          </select>
        </div>
        <div class="form-grid">
          <div>
            <div class="field-label">Tanggal konser</div>
            <input type="date" id="eventDate" />
          </div>
          <div>
            <div class="field-label">Jam mulai</div>
            <input type="time" id="eventTime" />
          </div>
        </div>
        <div class="form-grid">
          <textarea
            id="eventDesc"
            placeholder="Deskripsi event (artis, rundown, info penting...)"
            class="full"
          ></textarea>
        </div>
        <div class="form-grid three">
          <input type="number" id="regularPrice" placeholder="Harga Regular" />
          <input type="number" id="vipPrice" placeholder="Harga VIP" />
          <input type="number" id="discount" placeholder="Diskon (%)" />
        </div>
        <div class="form-grid">
          <input type="number" id="stockRegular" placeholder="Stok Regular" />
          <input type="number" id="stockVIP" placeholder="Stok VIP" />
        </div>
        <button
          class="btn btn-primary"
          onclick="addEvent()"
          style="margin-top: 2px"
        >
          <i class="ti ti-plus"></i> Tambah event
        </button>
      </div>

      <div class="panel">
        <div class="panel-title"><i class="ti ti-list"></i> Kelola event</div>
        <div class="search-wrap">
          <i class="ti ti-search"></i>
          <input
            type="text"
            id="searchInput"
            placeholder="Cari event..."
            onkeyup="searchEvent()"
          />
        </div>
        <table style="table-layout: fixed">
          <thead>
            <tr>
              <th style="width: 17%">Nama event</th>
              <th style="width: 13%">Tgl & Jam Konser</th>
              <th style="width: 13%">Lokasi</th>
              <th style="width: 8%">Regular</th>
              <th style="width: 8%">VIP</th>
              <th style="width: 6%">Diskon</th>
              <th style="width: 6%">Stok R</th>
              <th style="width: 6%">Stok V</th>
              <th style="width: 6%">Jual R</th>
              <th style="width: 6%">Jual V</th>
              <th style="width: 6%">Status</th>
              <th style="width: 5%">Aksi</th>
            </tr>
          </thead>
          <tbody id="eventTable"></tbody>
        </table>
      </div>

      <div class="panel">
        <div class="panel-title">
          <i class="ti ti-credit-card"></i> Pembayaran
        </div>
        <table style="table-layout: fixed">
          <thead>
            <tr>
              <th style="width: 15%">Waktu Pesan</th>
              <th style="width: 17%">User</th>
              <th style="width: 20%">Event</th>
              <th style="width: 10%">Tipe</th>
              <th style="width: 8%">Jumlah</th>
              <th style="width: 15%">Total</th>
              <th style="width: 15%">Status</th>
            </tr>
          </thead>
          <tbody id="paymentTable">
            <tr class="empty-row">
              <td colspan="7">Belum ada transaksi</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="panel">
        <div class="panel-title"><i class="ti ti-users"></i> Data user</div>
        <table style="table-layout: fixed">
          <thead>
            <tr>
              <th>Nama</th>
              <th>Email</th>
              <th>Total pembelian</th>
            </tr>
          </thead>
          <tbody>
            <tr class="empty-row">
              <td colspan="3">Belum ada data user</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="toast" id="toast">
      <i class="ti ti-circle-check"></i>
      <span id="toastMsg"></span>
    </div>

    <div class="modal-bg" id="editModal">
      <div class="modal">
        <h2><i class="ti ti-edit"></i> Edit event</h2>
        <div class="form-grid">
          <input
            type="text"
            id="editName"
            placeholder="Nama event"
            class="full"
          />
        </div>
        <div class="form-grid">
          <input type="text" id="editLocation" placeholder="Lokasi venue" />
          <select id="editStatus">
            <option>Aktif</option>
            <option>Selesai</option>
          </select>
        </div>
        <div class="form-grid">
          <div>
            <div class="field-label">Tanggal konser</div>
            <input type="date" id="editDate" />
          </div>
          <div>
            <div class="field-label">Jam mulai</div>
            <input type="time" id="editTime" />
          </div>
        </div>
        <div class="form-grid">
          <textarea
            id="editDesc"
            placeholder="Deskripsi event..."
            class="full"
          ></textarea>
        </div>
        <div class="form-grid three">
          <input type="number" id="editRegular" placeholder="Harga Regular" />
          <input type="number" id="editVIP" placeholder="Harga VIP" />
          <input type="number" id="editDiscount" placeholder="Diskon (%)" />
        </div>
        <div class="form-grid">
          <input type="number" id="editStockReg" placeholder="Stok Regular" />
          <input type="number" id="editStockVIP" placeholder="Stok VIP" />
        </div>
        <div class="modal-actions">
          <button class="btn btn-primary" onclick="saveEdit()">
            <i class="ti ti-check"></i> Simpan
          </button>
          <button class="btn btn-danger" onclick="closeModal('editModal')">
            <i class="ti ti-x"></i> Batal
          </button>
        </div>
      </div>
    </div>

    <div class="modal-bg" id="detailModal">
      <div class="modal">
        <h2><i class="ti ti-info-circle"></i> Detail event</h2>
        <div class="event-datetime-banner">
          <i class="ti ti-calendar-event"></i>
          <div>
            <div class="edb-main" id="dDateMain">—</div>
            <div class="edb-sub" id="dDateSub">—</div>
          </div>
        </div>
        <div class="detail-row">
          <span class="detail-label">Nama event</span>
          <span class="detail-value" id="dName"></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Lokasi</span>
          <div class="detail-icon-row">
            <i class="ti ti-map-pin"></i
            ><span class="detail-value" id="dLocation"></span>
          </div>
        </div>
        <div class="detail-row">
          <span class="detail-label">Deskripsi</span>
          <span
            class="detail-value"
            id="dDesc"
            style="white-space: pre-line"
          ></span>
        </div>
        <hr class="divider" />
        <div class="form-grid three" style="margin-bottom: 0">
          <div class="detail-row" style="margin-bottom: 0">
            <span class="detail-label">Harga Regular</span
            ><span class="detail-value" id="dRegular"></span>
          </div>
          <div class="detail-row" style="margin-bottom: 0">
            <span class="detail-label">Harga VIP</span
            ><span class="detail-value" id="dVip"></span>
          </div>
          <div class="detail-row" style="margin-bottom: 0">
            <span class="detail-label">Diskon</span
            ><span class="detail-value" id="dDiscount"></span>
          </div>
        </div>
        <hr class="divider" />
        <div class="form-grid" style="margin-bottom: 0">
          <div class="detail-row" style="margin-bottom: 0">
            <span class="detail-label">Stok Regular</span
            ><span class="detail-value" id="dStockReg"></span>
          </div>
          <div class="detail-row" style="margin-bottom: 0">
            <span class="detail-label">Stok VIP</span
            ><span class="detail-value" id="dStockVip"></span>
          </div>
        </div>
        <div class="modal-actions" style="margin-top: 16px">
          <button class="btn btn-ghost" onclick="closeModal('detailModal')">
            <i class="ti ti-x"></i> Tutup
          </button>
        </div>
      </div>
    </div>

    <script>
      let events = [];
      let payments = [];
      let currentIndex = -1;

      window.addEventListener(
        "scroll",
        () => {
          document
            .getElementById("navbar")
            .classList.toggle("scrolled", window.scrollY > 30);
        },
        { passive: true },
      );

      function showToast(msg) {
        const t = document.getElementById("toast");
        document.getElementById("toastMsg").textContent = msg;
        t.classList.add("show");
        setTimeout(() => t.classList.remove("show"), 2800);
      }

      function fmt(n) {
        return Number(n).toLocaleString("id-ID", {
          style: "currency",
          currency: "IDR",
          minimumFractionDigits: 0,
        });
      }
      function fmtDate(d) {
        return new Date(d).toLocaleDateString("id-ID", {
          day: "2-digit",
          month: "short",
          year: "numeric",
        });
      }
      function fmtTime(d) {
        return new Date(d).toLocaleTimeString("id-ID", {
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit",
        });
      }
      function fmtEventDate(dateStr) {
        if (!dateStr) return "—";
        const d = new Date(dateStr + "T00:00:00");
        return d.toLocaleDateString("id-ID", {
          weekday: "long",
          day: "2-digit",
          month: "long",
          year: "numeric",
        });
      }

      function updateStats() {
        document.getElementById("totalEvent").textContent = events.length;
        let tt = 0,
          sold = 0,
          rev = 0;
        events.forEach((e) => {
          tt += Number(e.stockReg) + Number(e.stockVIP);
          sold += Number(e.soldRegular) + Number(e.soldVIP);
          const rp = Number(e.regular) * (1 - Number(e.discount) / 100);
          const vp = Number(e.vip) * (1 - Number(e.discount) / 100);
          rev += Number(e.soldRegular) * rp + Number(e.soldVIP) * vp;
        });
        document.getElementById("totalTicket").textContent = tt;
        document.getElementById("ticketSold").textContent = sold;
        document.getElementById("revenue").textContent = fmt(rev);
      }

      function renderTable() {
        const tbody = document.getElementById("eventTable");
        tbody.innerHTML = "";
        if (!events.length) {
          tbody.innerHTML =
            '<tr class="empty-row"><td colspan="12">Belum ada event. Tambahkan di atas.</td></tr>';
        } else {
          events.forEach((e, i) => {
            const row = document.createElement("tr");
            row.style.animation = `fadeIn .2s ease ${i * 40}ms both`;
            const shortLoc = e.location
              ? e.location.length > 18
                ? e.location.slice(0, 18) + "…"
                : e.location
              : "—";
            const shortDate = e.date ? fmtDate(e.date + "T00:00:00") : "—";
            const shortTime = e.time || "—";

            let isLewat = false;
            if (e.date && e.time)
              isLewat = new Date(e.date + "T" + e.time) < new Date();
            else if (e.date)
              isLewat = new Date(e.date + "T23:59:59") < new Date();
            const statusLabel =
              e.status === "Aktif" && isLewat ? "Lewat" : e.status;
            const statusClass =
              e.status === "Aktif"
                ? isLewat
                  ? "badge-red"
                  : "badge-green"
                : "badge-gray";
            row.innerHTML = `
          <td style="font-weight:600">${e.name}</td>
          <td>
            <div class="date-cell">
              <span class="date-main">${shortDate}</span>
              <span class="date-time">${shortTime}</span>
            </div>
          </td>
          <td><div class="loc-cell"><i class="ti ti-map-pin"></i>${shortLoc}</div></td>
          <td>${fmt(e.regular)}</td>
          <td>${fmt(e.vip)}</td>
          <td>${e.discount}%</td>
          <td>${e.stockReg}</td>
          <td>${e.stockVIP}</td>
          <td>${e.soldRegular}</td>
          <td>${e.soldVIP}</td>
          <td><span class="badge ${statusClass}">${statusLabel}</span></td>
          <td>
            <div style="display:flex;gap:4px">
              <button class="btn btn-ghost btn-sm" onclick="showDetail(${i})" title="Detail"><i class="ti ti-eye"></i></button>
              <button class="btn btn-warn btn-sm"  onclick="editEvent(${i})"  title="Edit"><i class="ti ti-edit"></i></button>
              <button class="btn btn-danger btn-sm" onclick="deleteEvent(${i})" title="Hapus"><i class="ti ti-trash"></i></button>
            </div>
          </td>`;
            tbody.appendChild(row);
          });
        }
        updateStats();
      }

      function renderPayments() {
        const tbody = document.getElementById("paymentTable");
        tbody.innerHTML = "";
        if (!payments.length) {
          tbody.innerHTML =
            '<tr class="empty-row"><td colspan="7">Belum ada transaksi</td></tr>';
          return;
        }
        [...payments].reverse().forEach((p, i) => {
          const row = document.createElement("tr");
          row.style.animation = `fadeIn .2s ease ${i * 30}ms both`;
          const sb =
            p.status === "Sukses"
              ? "badge-green"
              : p.status === "Pending"
                ? "badge-yellow"
                : "badge-gray";
          row.innerHTML = `
        <td>
          <div class="time-cell">
            <span class="time-date">${fmtDate(p.time)}</span>
            <span class="time-hour">${fmtTime(p.time)}</span>
          </div>
        </td>
        <td>${p.user}</td>
        <td>${p.event}</td>
        <td><span class="badge ${p.type === "VIP" ? "badge-yellow" : "badge-gray"}">${p.type}</span></td>
        <td style="text-align:center">${p.qty}</td>
        <td>${fmt(p.total)}</td>
        <td><span class="badge ${sb}">${p.status}</span></td>`;
          tbody.appendChild(row);
        });
      }

      function addEvent() {
        const name = document.getElementById("eventName").value.trim();
        if (!name) {
          alert("Nama event wajib diisi");
          return;
        }
        events.push({
          name,
          location: document.getElementById("eventLocation").value.trim(),
          date: document.getElementById("eventDate").value,
          time: document.getElementById("eventTime").value,
          desc: document.getElementById("eventDesc").value.trim(),
          regular: document.getElementById("regularPrice").value || 0,
          vip: document.getElementById("vipPrice").value || 0,
          discount: document.getElementById("discount").value || 0,
          stockReg: document.getElementById("stockRegular").value || 0,
          stockVIP: document.getElementById("stockVIP").value || 0,
          soldRegular: 0,
          soldVIP: 0,
          status: document.getElementById("statusEvent").value,
        });
        [
          "eventName",
          "eventLocation",
          "eventDate",
          "eventTime",
          "eventDesc",
          "regularPrice",
          "vipPrice",
          "discount",
          "stockRegular",
          "stockVIP",
        ].forEach((id) => (document.getElementById(id).value = ""));
        renderTable();
        showToast('"' + name + '" berhasil ditambahkan');
      }

      function deleteEvent(i) {
        if (confirm('Hapus event "' + events[i].name + '"?')) {
          const n = events[i].name;
          events.splice(i, 1);
          renderTable();
          showToast('"' + n + '" dihapus');
        }
      }

      function showDetail(i) {
        const e = events[i];
        document.getElementById("dDateMain").textContent = fmtEventDate(e.date);
        document.getElementById("dDateSub").textContent = e.time
          ? "Jam " + e.time + " WIB"
          : "Jam belum ditentukan";
        document.getElementById("dName").textContent = e.name;
        document.getElementById("dLocation").textContent = e.location || "—";
        document.getElementById("dDesc").textContent =
          e.desc || "Tidak ada deskripsi";
        document.getElementById("dRegular").textContent = fmt(e.regular);
        document.getElementById("dVip").textContent = fmt(e.vip);
        document.getElementById("dDiscount").textContent = e.discount + "%";
        document.getElementById("dStockReg").textContent =
          e.stockReg + " tiket";
        document.getElementById("dStockVip").textContent =
          e.stockVIP + " tiket";
        document.getElementById("detailModal").classList.add("open");
      }

      function editEvent(i) {
        currentIndex = i;
        const e = events[i];
        document.getElementById("editName").value = e.name;
        document.getElementById("editLocation").value = e.location;
        document.getElementById("editDate").value = e.date;
        document.getElementById("editTime").value = e.time;
        document.getElementById("editDesc").value = e.desc;
        document.getElementById("editRegular").value = e.regular;
        document.getElementById("editVIP").value = e.vip;
        document.getElementById("editDiscount").value = e.discount;
        document.getElementById("editStockReg").value = e.stockReg;
        document.getElementById("editStockVIP").value = e.stockVIP;
        document.getElementById("editStatus").value = e.status;
        document.getElementById("editModal").classList.add("open");
      }

      function saveEdit() {
        const name = document.getElementById("editName").value;
        events[currentIndex] = {
          name,
          location: document.getElementById("editLocation").value.trim(),
          date: document.getElementById("editDate").value,
          time: document.getElementById("editTime").value,
          desc: document.getElementById("editDesc").value.trim(),
          regular: document.getElementById("editRegular").value,
          vip: document.getElementById("editVIP").value,
          discount: document.getElementById("editDiscount").value,
          stockReg: document.getElementById("editStockReg").value,
          stockVIP: document.getElementById("editStockVIP").value,
          soldRegular: events[currentIndex].soldRegular,
          soldVIP: events[currentIndex].soldVIP,
          status: document.getElementById("editStatus").value,
        };
        renderTable();
        closeModal("editModal");
        showToast('"' + name + '" berhasil diperbarui');
      }

      function closeModal(id) {
        document.getElementById(id).classList.remove("open");
      }

      function searchEvent() {
        const kw = document.getElementById("searchInput").value.toLowerCase();
        document.querySelectorAll("#eventTable tr").forEach((r) => {
          r.style.display = r.innerText.toLowerCase().includes(kw)
            ? ""
            : "none";
        });
      }

      renderTable();
      renderPayments();
    </script>
  </body>
</html>
