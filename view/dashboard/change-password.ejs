<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Ganti Password</title>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            background:#f4f6f9;
            display:flex;
            justify-content:center;
            align-items:center;
            height:100vh;
        }

        .container{
            width:420px;
            background:white;
            padding:35px;
            border-radius:15px;
            box-shadow:0 10px 25px rgba(0,0,0,.15);
        }

        h2{
            text-align:center;
            color:#1e293b;
            margin-bottom:25px;
        }

        label{
            font-weight:bold;
            display:block;
            margin-bottom:8px;
        }

        input{
            width:100%;
            padding:12px;
            margin-bottom:18px;
            border:1px solid #ccc;
            border-radius:8px;
            font-size:15px;
        }

        input:focus{
            outline:none;
            border:1px solid #2563eb;
        }

        .btn{
            width:100%;
            padding:12px;
            border:none;
            border-radius:8px;
            cursor:pointer;
            font-size:15px;
            margin-top:5px;
        }

        .save{
            background:#2563eb;
            color:white;
        }

        .save:hover{
            background:#1d4ed8;
        }

        .back{
            background:#64748b;
            color:white;
            margin-top:10px;
        }

        .back:hover{
            background:#475569;
        }

    </style>

</head>

<body>

<div class="container">

    <h2>🔐 Ganti Password Kamu Disini !</h2>

    <form action="/api/change-password" method="POST">

        <label>Password Lama</label>
        <input
            type="password"
            name="oldPassword"
            placeholder="Masukkin Password Lama"
            required>

        <label>Password Baru</label>
        <input
            type="password"
            name="newPassword"
            placeholder="Masukkin password baru"
            required>

        <label>Konfirmasi Password</label>
        <input
            type="password"
            name="confirmPassword"
            placeholder="Ulangin password baru"
            required>

        <button class="btn save">
            Save Password!
        </button>

    </form>

<a href="/user/dashboard">
    <button class="btn back">
        ← Kembali ke Dashboard
    </button>
</a>
</div>

</body>
</html>