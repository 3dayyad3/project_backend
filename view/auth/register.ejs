<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Register</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #0f1117;
      color: #e8eaf0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .card {
      background: #1a1d27;
      border: 1px solid #2a2d3a;
      border-radius: 16px;
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 400px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    }

    .logo { text-align: center; margin-bottom: 1.75rem; }
    .logo .icon { font-size: 2.5rem; margin-bottom: .5rem; }
    .logo h2    { font-size: 1.4rem; font-weight: 700; }
    .logo p     { font-size: .875rem; color: #8b8fa8; margin-top: .25rem; }

    .alert {
      padding: .75rem 1rem;
      border-radius: 8px;
      font-size: .85rem;
      margin-bottom: 1rem;
      display: none;
    }
    .alert.show    { display: block; }
    .alert.error   { background: rgba(255,77,79,.12); border: 1px solid rgba(255,77,79,.3); color: #ff7875; }
    .alert.success { background: rgba(82,196,26,.12);  border: 1px solid rgba(82,196,26,.3);  color: #95de64; }

    .form-group { margin-bottom: 1rem; }

    .form-group label {
      display: block;
      font-size: .8rem;
      font-weight: 600;
      color: #8b8fa8;
      margin-bottom: .4rem;
      text-transform: uppercase;
      letter-spacing: .3px;
    }

    .form-group input {
      width: 100%;
      background: #0f1117;
      border: 1.5px solid #2a2d3a;
      border-radius: 8px;
      padding: .7rem 1rem;
      color: #e8eaf0;
      font-size: .9rem;
      outline: none;
      transition: border-color .2s;
    }

    .form-group input:focus { border-color: #6c63ff; }
    .form-group input::placeholder { color: #8b8fa8; opacity: .6; }

    .btn {
      width: 100%;
      padding: .8rem;
      background: #6c63ff;
      color: #fff;
      border: none;
      border-radius: 10px;
      font-size: .95rem;
      font-weight: 700;
      cursor: pointer;
      margin-top: .5rem;
      transition: background .2s;
    }

    .btn:hover  { background: #8b85ff; }
    .btn:active { transform: scale(.98); }

    .footer {
      text-align: center;
      margin-top: 1.25rem;
      font-size: .85rem;
      color: #8b8fa8;
    }

    .footer a { color: #6c63ff; text-decoration: none; font-weight: 600; }
    .footer a:hover { text-decoration: underline; }
  </style>
</head>
<body>

  <div class="card">

    <div class="logo">
      <h2>Buat Akun Baru</h2>
      <p>Daftarkan diri Anda sekarang</p>
    </div>

    <div class="alert" id="alert"></div>

    <div class="form-group">
      <label>Nama</label>
      <input type="text" id="name" placeholder="Nama lengkap"/>
    </div>

    <div class="form-group">
      <label>Email</label>
      <input type="email" id="email" placeholder="email@example.com"/>
    </div>

    <div class="form-group">
      <label>Password</label>
      <input type="password" id="password" placeholder="password"/>
    </div>

    <button class="btn" onclick="handleRegister()">Daftar</button>

    <div class="footer">
      Sudah punya akun? <a href="/">Masuk di sini</a>
    </div>

  </div>

  <script>
    async function handleRegister() {
      const name      = document.getElementById('name').value.trim();
      const email     = document.getElementById('email').value.trim();
      const password  = document.getElementById('password').value;
      const alertEl   = document.getElementById('alert');

      alertEl.className = 'alert';

      if (!name || !email || !password) {
        alertEl.textContent = 'Semua field wajib diisi.';
        alertEl.className = 'alert error show';
        return;
      }

      try {
        const res = await fetch('/api/user', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, password }),
        });

        const { success, message } = await res.json();

        if (!success) {
          alertEl.textContent = message;
          alertEl.className = 'alert error show';
          return;
        }

        alertEl.textContent = 'Registrasi berhasil! Silakan login.';
        alertEl.className = 'alert success show';
        setTimeout(() => { window.location.href = '/'; }, 1500);

      } catch (err) {
        alertEl.textContent = 'Gagal terhubung ke server.';
        alertEl.className = 'alert error show';
      }
    }
  </script>

</body>
</html>