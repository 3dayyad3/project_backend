<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #0f1117;
      color: #e8eaf0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .card {
      background: #1a1d27;
      border: 1px solid #2a2d3a;
      border-radius: 16px;
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 400px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    }

    .logo {
      text-align: center;
      margin-bottom: 1.75rem;
    }

    .logo .icon {
      font-size: 2.5rem;
      margin-bottom: .5rem;
    }

    .logo h2 {
      font-size: 1.4rem;
      font-weight: 700;
    }

    .logo p {
      font-size: .875rem;
      color: #8b8fa8;
      margin-top: .25rem;
    }

    .tab-bar {
      display: flex;
      background: #0f1117;
      border-radius: 10px;
      padding: 4px;
      margin-bottom: 1.5rem;
      gap: 4px;
    }

    .tab-bar button {
      flex: 1;
      padding: .5rem;
      border: none;
      background: transparent;
      color: #8b8fa8;
      border-radius: 8px;
      font-size: .875rem;
      font-weight: 500;
      cursor: pointer;
      transition: all .2s;
    }

    .tab-bar button.active {
      background: #1a1d27;
      color: #e8eaf0;
      box-shadow: 0 1px 4px rgba(0,0,0,.4);
    }

    .alert {
      background: rgba(255,77,79,.12);
      border: 1px solid rgba(255,77,79,.3);
      color: #ff7875;
      padding: .75rem 1rem;
      border-radius: 8px;
      font-size: .85rem;
      margin-bottom: 1rem;
      display: none;
    }

    .alert.show { display: block; }

    .form-group {
      margin-bottom: 1rem;
    }

    .form-group label {
      display: block;
      font-size: .8rem;
      font-weight: 600;
      color: #8b8fa8;
      margin-bottom: .4rem;
      text-transform: uppercase;
      letter-spacing: .3px;
    }

    .form-group input {
      width: 100%;
      background: #0f1117;
      border: 1.5px solid #2a2d3a;
      border-radius: 8px;
      padding: .7rem 1rem;
      color: #e8eaf0;
      font-size: .9rem;
      outline: none;
      transition: border-color .2s;
    }

    .form-group input:focus {
      border-color: #6c63ff;
    }

    .form-group input::placeholder {
      color: #8b8fa8;
      opacity: .6;
    }

    .btn {
      width: 100%;
      padding: .8rem;
      background: #6c63ff;
      color: #fff;
      border: none;
      border-radius: 10px;
      font-size: .95rem;
      font-weight: 700;
      cursor: pointer;
      margin-top: .5rem;
      transition: background .2s;
    }

    .btn:hover { background: #8b85ff; }
    .btn:active { transform: scale(.98); }

    .footer {
      text-align: center;
      margin-top: 1.25rem;
      font-size: .85rem;
      color: #8b8fa8;
    }

    .footer a {
      color: #6c63ff;
      text-decoration: none;
      font-weight: 600;
    }

    .footer a:hover { text-decoration: underline; }
  </style>
</head>
<body>

  <div class="card">

    <div class="logo">
      <h2>Selamat Datang</h2>
      <p>Masuk ke akun Anda</p>
    </div>

    <div class="tab-bar">
      <button id="tab-user"  class="active" onclick="switchRole('user')"> User</button>
      <button id="tab-admin"               onclick="switchRole('admin')"> Admin</button>
    </div>

    <div class="alert" id="alert"></div>

    <div class="form-group">
      <label>Email</label>
      <input type="email" id="email" placeholder="nama@email.com"/>
    </div>

    <div class="form-group">
      <label>Password</label>
      <input type="password" id="password" placeholder="Masukkan password"/>
    </div>

    <button class="btn" onclick="handleLogin()">Masuk</button>

    <div class="footer">
      Belum punya akun? <a href="/register">Daftar sekarang</a>
    </div>

  </div>

  <script>
    let currentRole = 'user';

    function switchRole(role) {
      currentRole = role;
      document.getElementById('tab-user').classList.toggle('active',  role === 'user');
      document.getElementById('tab-admin').classList.toggle('active', role === 'admin');
    }

    async function handleLogin() {
      const email   = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;
      const alertEl  = document.getElementById('alert');

      alertEl.classList.remove('show');

      if (!email || !password) {
        alertEl.textContent = 'Email dan password wajib diisi.';
        alertEl.classList.add('show');
        return;
      }

      const url = currentRole === 'user' ? '/api/user/login' : '/api/admin/login';

      try {
        const res = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });

        const { success, message, data } = await res.json();

        if (!success) {
          alertEl.textContent = message;
          alertEl.classList.add('show');
          return;
        }

        //const token = data[0].token;
        if (currentRole === 'user') {
          //localStorage.setItem('token', token);
          window.location.href = '/user/dashboard';
        } else {
          //localStorage.setItem('adminToken', token);
          window.location.href = '/admin/dashboard';
        }

      } catch (err) {
        alertEl.textContent = 'Gagal terhubung ke server.';
        alertEl.classList.add('show');
      }
    }
  </script>

</body>
</html>